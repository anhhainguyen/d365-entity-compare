{
  "manifest_version": 3,
  "name": "D365 Entity Compare",
  "version": "1.0.0",
  "short_name": "D365 Compare",
  "description": "Compare D365 F&O Data Entities between two environments.",
  "author": "Hai Nguyen",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "D365 Entity Compare",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "https://*.cloudax.dynamics.com/*",
    "https://*.dynamics.com/*",
    "https://*.operations.dynamics.com/*",
    "https://*.sandbox.operations.dynamics.com/*"
  ],
  "content_scripts": [{
    "js": ["content.js"],
    "matches": [
      "https://*.cloudax.dynamics.com/*",
      "https://*.dynamics.com/*",
      "https://*.operations.dynamics.com/*",
      "https://*.sandbox.operations.dynamics.com/*"
    ],
    "run_at": "document_idle"
  }]
}
